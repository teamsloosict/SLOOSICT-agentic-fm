#!/usr/bin/env npx tsx
/**
 * generate-step-catalog.ts
 *
 * Generates agent/catalogs/step-catalog-en.json from:
 * - agent/snippet_examples/steps/**\/*.xml  (canonical XML templates)
 * - Hardcoded step ID mappings (from Rust constants.rs)
 * - Hardcoded HR signatures and Monaco snippets (from existing converters)
 *
 * Run: npx tsx agent/scripts/generate-step-catalog.ts
 */

import * as fs from 'fs';
import * as path from 'path';
import { fileURLToPath } from 'url';

// ── Types (inline for standalone execution) ──────────────────────────

interface StepCatalogEntry {
  name: string;
  id: number | null;
  category: string;
  snippetFile: string;
  selfClosing: boolean;
  params: StepParam[];
  hrSignature: string | null;
  monacoSnippet: string | null;
  blockPair: { role: 'open' | 'close' | 'middle'; partners: string[] } | null;
  status: 'auto' | 'reviewed' | 'complete';
  helpUrl: string | null;
}

interface StepParam {
  xmlElement: string;
  type: 'boolean' | 'enum' | 'calculation' | 'namedCalc' | 'field' | 'layout' | 'script' | 'table' | 'text' | 'name' | 'complex';
  hrLabel: string | null;
  xmlAttr?: string;
  enumValues?: string[];
  wrapperElement?: string;
  required: boolean;
  defaultValue?: string;
  description?: string;
}

interface CommentMeta {
  enums: Record<string, string[]>;
  helpUrl: string | null;
  required: string[];
  optional: string[];
}

// ── Step ID mapping (from Rust constants.rs) ─────────────────────────

const STEP_IDS: Record<string, number> = {
  'Perform Script': 1,
  'Go to Previous Field': 4,
  'Go to Next Field': 5,
  'Go to Layout': 6,
  'New Record/Request': 7,
