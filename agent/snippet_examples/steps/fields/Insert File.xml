<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="0" name="Insert File">
    <UniversalPathList type="Embedded">$path</UniversalPathList>
    <Text/>
    <Field>$file</Field>
    <DialogOptions asFile="True" enable="True">
      <Title>
        <Calculation><![CDATA["Dialog title"]]></Calculation>
      </Title>
      <Storage type="InsertOnly"/>
      <Compress type="WhenPossible"/>
      <FilterList/>
    </DialogOptions>
  </Step>
</fmxmlsnippet>
<!-- UniversalPathList type: "Embedded" (embeds the file) | "Reference" (stores only a link to the file). -->
<!-- DialogOptions enable: "True" shows custom Insert File dialog. "False" suppresses dialog. -->
<!-- DialogOptions asFile: "True" stores as a file (icon display). "False" displays content when possible. -->
<!-- Storage type: "InsertOnly" | "ReferenceOnly" | "InsertAndReference" -->
<!-- Compress type: "WhenPossible" | "Never" -->
<!-- Target: Field element uses <Field table="" id="0" name=""/> for a container field, or <Field>$variable</Field> for a variable. -->
<!-- Optional: UniversalPathList (source file path; if omitted, user is prompted), DialogOptions, Target. If Target is omitted, the active container field is used; returns an error if no active container field. -->
<!-- If targeting a variable that does not exist, this step creates it. -->
<!-- In FileMaker Go: Storage is always Insert; Display is always Content of file (when possible). -->
<!-- See https://help.claris.com/en/pro-help/content/insert-file.html -->
