---
import Base from '../layouts/Base.astro';
import { GALLERY_THEMES, type GalleryTheme } from '../data/themes';

function previewHtml(theme: GalleryTheme): string {
  const c = theme.colors;
  return [
    `<span style="color:${c.comments}"># Calculate invoice total</span>`,
    `<span style="color:${c.controlFlow}">If</span> <span style="color:${c.brackets}">[</span> <span style="color:${c.variables}">$count</span> <span style="color:${c.operators}">&gt;</span> <span style="color:${c.numbers}">0</span> <span style="color:${c.brackets}">]</span>`,
    `  <span style="color:${c.scriptSteps}">Set Field</span> <span style="color:${c.brackets}">[</span> <span style="color:${c.fields}">Invoices::Total</span> <span style="color:${c.operators}">;</span> <span style="color:${c.functions}">Sum</span> <span style="color:${c.brackets}">(</span> <span style="color:${c.fields}">LineItems::Amount</span> <span style="color:${c.brackets}">)</span> <span style="color:${c.brackets}">]</span>`,
    `  <span style="color:${c.scriptSteps}">Set Variable</span> <span style="color:${c.brackets}">[</span> <span style="color:${c.variables}">$msg</span> <span style="color:${c.operators}">;</span> <span style="color:${c.strings}">"Processed"</span> <span style="color:${c.brackets}">]</span>`,
    `<span style="color:${c.controlFlow}">End If</span>`,
  ].join('\n');
}
---

<Base
  title="Theme Gallery"
  description="Browse and copy FileMaker editor themes for the agentic-fm webviewer."
>
  <section class="border-b border-zinc-200 py-16 dark:border-zinc-800">
    <div class="mx-auto max-w-6xl px-6">
      <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-white">
        Theme Gallery
      </h1>
      <p class="mt-3 max-w-2xl text-lg text-zinc-600 dark:text-zinc-400">
        Browse themes for the webviewer editor. Click <strong>Copy JSON</strong> on any card,
        then paste it into <strong>Settings → Editor → Import theme</strong> in the webviewer.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {GALLERY_THEMES.map((theme) => (
          <div class="rounded-xl border border-zinc-200 bg-white shadow-sm dark:border-zinc-700 dark:bg-zinc-900">
            <div class="p-4">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h2 class="text-sm font-semibold text-zinc-900 dark:text-white">{theme.name}</h2>
                  {theme.credit && (
                    <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">
                      by{' '}
                      {theme.creditUrl
                        ? <a href={theme.creditUrl} class="hover:underline" target="_blank" rel="noopener">{theme.credit}</a>
                        : theme.credit}
                    </p>
                  )}
                </div>
              </div>

              {/* Syntax preview */}
              <pre
                class="rounded-lg p-3 text-xs leading-relaxed overflow-x-auto font-mono"
                style="background:#1E1E1E"
                set:html={previewHtml(theme)}
              />
            </div>

            <div class="border-t border-zinc-100 dark:border-zinc-800 px-4 py-3 flex items-center justify-between">
              <div class="flex gap-1.5">
                {Object.values(theme.colors).slice(0, 8).map((color) => (
                  <span
                    class="w-3.5 h-3.5 rounded-full border border-zinc-300 dark:border-zinc-600"
                    style={`background:${color}`}
                    title={color}
                  />
                ))}
              </div>
              <button
                class="copy-btn text-xs px-3 py-1 rounded bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700 text-zinc-700 dark:text-zinc-300 transition-colors"
                data-theme={JSON.stringify(theme.colors)}
              >
                Copy JSON
              </button>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 rounded-xl border border-zinc-200 dark:border-zinc-700 p-6 max-w-2xl">
        <h2 class="text-sm font-semibold text-zinc-900 dark:text-white mb-2">How to use</h2>
        <ol class="text-sm text-zinc-600 dark:text-zinc-400 space-y-1 list-decimal list-inside">
          <li>Click <strong>Copy JSON</strong> on any theme card above.</li>
          <li>Open the webviewer and go to <strong>Settings → Editor</strong>.</li>
          <li>Click <strong>Import theme</strong> and paste the JSON into the textarea.</li>
          <li>Click <strong>Apply imported colors</strong>. Fine-tune with the color swatches.</li>
        </ol>
        <p class="mt-3 text-xs text-zinc-500 dark:text-zinc-500">
          You can also import any VS Code / TextMate theme JSON — the importer maps TextMate scopes
          to the 12 FileMaker token categories automatically.
        </p>
      </div>
    </div>
  </section>
</Base>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const themeJson = btn.dataset.theme ?? '';
      try {
        await navigator.clipboard.writeText(themeJson);
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {
        btn.textContent = 'Failed';
      }
    });
  });
</script>
