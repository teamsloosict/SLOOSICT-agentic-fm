---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 dark:border-zinc-800">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={base} class="flex items-center gap-2.5 font-semibold text-zinc-900 dark:text-white">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary-600 text-sm font-bold text-white">
            fm
          </span>
          agentic-fm
        </a>
        <p class="mt-3 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
          The agentic harness for empowering Claris FileMaker.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-zinc-900 dark:text-white">Documentation</h4>
        <ul class="mt-3 space-y-2">
          <li><a href={`${base}docs/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Overview</a></li>
          <li><a href={`${base}skills/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Skills</a></li>
          <li><a href={`${base}installation/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Installation</a></li>
          <li><a href={`${base}webviewer/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Webviewer</a></li>
          <li><a href={`${base}philosophy/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Philosophy</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-zinc-900 dark:text-white">Community</h4>
        <ul class="mt-3 space-y-2">
          <li><a href={`${base}contributing/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Contributing</a></li>
          <li><a href="https://github.com/petrowsky/agentic-fm/issues" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Issues</a></li>
          <li><a href="https://github.com/petrowsky/agentic-fm/discussions" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Discussions</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-zinc-900 dark:text-white">Resources</h4>
        <ul class="mt-3 space-y-2">
          <li><a href="https://github.com/petrowsky/agentic-fm" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">GitHub</a></li>
          <li><a href="https://github.com/petrowsky/agentic-fm/releases" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Releases</a></li>
          <li><a href="https://github.com/petrowsky/agentic-fm/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">License</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-zinc-200 pt-8 dark:border-zinc-800 sm:flex-row">
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        &copy; {year} agentic-fm contributors. Open source under Apache 2.0.
      </p>
      <a
        href="https://github.com/petrowsky/agentic-fm"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
      >
        Built with Astro
      </a>
    </div>
  </div>
</footer>
