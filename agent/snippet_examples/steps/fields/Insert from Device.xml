<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="0" name="Insert from Device">
    <InsertFrom value="Camera"/>
    <Field table="" id="0" name=""/>
    <DeviceOptions>
      <Camera choice="Back"/>
      <Resolution choice="Full"/>
    </DeviceOptions>
  </Step>
</fmxmlsnippet>
<!-- InsertFrom value: "Camera" | "VideoCamera" | "Microphone" | "PhotoLibrary" | "MusicLibrary" | "BarcodeScanCamera" | "BarcodeScanField" | "Signature" -->
<!-- Camera choice: "Back" | "Front" -->
<!-- Resolution choice: "Full" | "Large" | "Medium" | "Small" -->
<!-- Optional: Field (target container or text field for barcodes). If omitted, the active container/text field is used; returns an error if field not on layout. -->
<!-- Optional DeviceOptions children (depend on InsertFrom): Camera, Resolution, MaxDuration (calculation, seconds), StartImmediately, BarcodeTypes, Title, Message, Prompt, Presentation. -->
<!-- Signature Presentation: "FullScreen" | "Overlay" | "Embedded" (falls back to Overlay if container is too small). -->
<!-- FileMaker Go only; not supported on Pro, WebDirect, Server, Cloud, Data API, or CWP. -->
<!-- Barcode in container field: image stored, text value retrievable via GetAsText; barcode type via GetContainerAttribute. In text field: only the text value is inserted. -->

